# Giscus comments configuration
# Fill these values from https://giscus.app after enabling GitHub Discussions.

# Required: GitHub repository in owner/repo format
NEXT_PUBLIC_GISCUS_REPO=your-github-id/your-repo

# Required: Repository ID from giscus.app
NEXT_PUBLIC_GISCUS_REPO_ID=R_kgDOxxxxxxxx

# Required: Discussion category name and ID from giscus.app
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOxxxxxxxx

# Optional
NEXT_PUBLIC_GISCUS_MAPPING=pathname
NEXT_PUBLIC_GISCUS_STRICT=0
NEXT_PUBLIC_GISCUS_REACTIONS_ENABLED=1
NEXT_PUBLIC_GISCUS_EMIT_METADATA=0
NEXT_PUBLIC_GISCUS_INPUT_POSITION=bottom
NEXT_PUBLIC_GISCUS_LANG=ko
